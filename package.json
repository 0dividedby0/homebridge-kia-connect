{
  "private": false,
  "displayName": "Kia Connect",
  "name": "homebridge-kia-connect-us",
  "version": "1.1.4",
  "description": "Homebridge plugin for Kia Connect — remote start/stop, lock/unlock, and climate profiles",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0dividedby0/homebridge-kia-connect.git"
  },
  "keywords": [
    "homebridge-plugin"
  ],
  "files": [
    "dist",
    "config.schema.json",
    "README.md",
    "LICENSE*"
  ],
  "engines": {
    "node": "^18.20.4 || ^20.15.1 || ^22.12.0 || ^24.0.0",
    "homebridge": "^1.6.0 || ^2.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "watch": "npm run build && npm link && nodemon",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "dev:homebridge": "homebridge -D -I -U ./.homebridge-dev -P . --strict-plugin-resolution",
    "smoke:homebridge": "homebridge -D -I -Q -U ./.homebridge-smoke -P . --strict-plugin-resolution",
    "dev:smoke": "npm run build && npm run dev:homebridge",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "exponential-backoff": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "homebridge": "^1.11.4",
    "nodemon": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  }
}
